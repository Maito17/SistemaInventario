SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=false
ENVIRONMENT=production

# ==========================================
# BASE DE DATOS
# ==========================================
# Railway proporciona DATABASE_URL automáticamente
DATABASE_URL=postgresql://usuario:password@localhost:5432/sistema_inventario

# Variables individuales (si no usas DATABASE_URL)
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=sistema_inventario
DATABASE_USER=usuario_db
DATABASE_PASSWORD=tu_password_aqui
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ==========================================
# RESPALDOS (BACKUP)
# ==========================================
BACKUP_ENABLED=True
BACKUP_COMPRESS=True
BACKUP_LOCAL_PATH=backup/respaldos/

# Google Drive para almacenar respaldos en nube
GOOGLE_DRIVE_ENABLED=False
GOOGLE_DRIVE_CREDENTIALS=
GOOGLE_DRIVE_FOLDER_ID=

# AWS S3 (alternativa a Google Drive)
AWS_S3_ENABLED=False
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================
# EMAIL (Notificaciones)
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_email@gmail.com
EMAIL_HOST_PASSWORD=tu_contraseña_app
EMAIL_USE_TLS=True
EMAIL_FROM=noreply@sistema-inventario.com

# ==========================================
# APIs EXTERNAS
# ==========================================
GEMINI_API_KEY=

# Slack (notificaciones de respaldos)
SLACK_ENABLED=False
SLACK_WEBHOOK_URL=

# ==========================================
# RAILWAY ESPECÍFICO
# ==========================================
RAILWAY_ENVIRONMENT=
# PORT se proporciona automáticamente en Railway

# ==========================================
# DESARROLLO LOCAL
# ==========================================
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

